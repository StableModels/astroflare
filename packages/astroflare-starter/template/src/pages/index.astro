---
import Base from "../layouts/Base.astro";
const greeting = "Welcome to your new Astroflare site";
---
<Base title="Home">
	<h1>{greeting}</h1>
	<p>Edit <code>src/pages/index.astro</code> to customise this page.</p>
	<ul>
		<li><a href="/about">about</a> (markdown)</li>
		<li><a href="/posts/hello-world">posts/hello-world</a> (dynamic route)</li>
	</ul>
</Base>
