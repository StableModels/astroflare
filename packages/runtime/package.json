{
  "name": "@astroflare/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./internal": {
      "types": "./src/internal.ts",
      "default": "./src/internal.ts"
    },
    "./components": {
      "types": "./src/components.ts",
      "default": "./src/components.ts"
    },
    "./jsx-runtime": {
      "types": "./src/jsx-runtime.ts",
      "default": "./src/jsx-runtime.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./src/jsx-runtime.ts",
      "default": "./src/jsx-runtime.ts"
    },
    "./env": {
      "types": "./src/env.ts",
      "default": "./src/env.ts"
    }
  },
  "scripts": {
    "test": "vitest run --project runtime"
  },
  "dependencies": {
    "@astroflare/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "happy-dom": "^15.11.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vitest": "^2.1.8"
  }
}
