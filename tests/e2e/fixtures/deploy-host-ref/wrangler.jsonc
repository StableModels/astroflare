{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "deploy-host-ref",
	"main": "src/worker.ts",
	"compatibility_date": "2025-09-01",
	"compatibility_flags": ["nodejs_compat"],
	"r2_buckets": [
		{
			"binding": "SITE_BUCKET",
			"bucket_name": "deploy-host-ref-files"
		}
	],
	"vars": {
		"SITE_PREFIX": ""
	}
}
