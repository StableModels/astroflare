# direnv configuration for the astroflare repo.
#
# When you `cd` into this directory, direnv loads every key/value pair
# from `.dev.vars` into the shell environment (and unloads them when
# you `cd` out). `wrangler dev` and any other tool that reads from
# `process.env` then sees them automatically.
#
# `.dev.vars` is git-crypt-filtered; before you've run `./scripts/setup`
# the file on disk is encrypted bytes and the loader below silently
# fails to parse it. After unlock it's plaintext and loads cleanly.
#
# Authorize this file with `direnv allow .` (the setup script does
# that for you).
#
# Non-secret project defaults are exported here directly (no encryption,
# no 1Password round-trip). The Cloudflare account ID is the address of
# the account that hosts deploys + e2e infrastructure for this repo — it
# pairs naturally with `CLOUDFLARE_API_TOKEN` (which is encrypted in
# `.dev.vars`).
#
# Pre-existing env vars win over `.dev.vars`. CI workflows (and any
# shell that pre-exports CLOUDFLARE_* before sourcing this file) get
# their values left alone — the dotfile only supplies what's missing.
# This matters because GitHub Actions exports the secret token via the
# job env block, and we don't want a stale local `.dev.vars` to clobber
# it on a self-hosted runner.

export CLOUDFLARE_ACCOUNT_ID="${CLOUDFLARE_ACCOUNT_ID:-4ef06593037ec81daf64e272ab950efb}"

if [ -f .dev.vars ]; then
	# Skip blank lines + `#` comments. Skip the GITCRYPT magic header
	# (first 10 bytes of the encrypted form) so a still-locked file
	# doesn't dump binary into the env. Set each key only if it isn't
	# already in the environment — so an explicit `export FOO=bar`
	# upstream of direnv (or a CI secret) wins over `.dev.vars`.
	while IFS='=' read -r key val; do
		case "$key" in
			""|\#*) continue ;;
			*GITCRYPT*) break ;;
		esac
		# Strip surrounding quotes from val if present (dotenv convention).
		val="${val%\"}"
		val="${val#\"}"
		val="${val%\'}"
		val="${val#\'}"
		if [ -z "${!key+x}" ]; then
			export "$key=$val"
		fi
	done < .dev.vars
fi

