# direnv configuration for the astroflare repo.
#
# When you `cd` into this directory, direnv loads every key/value pair
# from `.dev.vars` into the shell environment (and unloads them when
# you `cd` out). `wrangler dev` and any other tool that reads from
# `process.env` then sees them automatically.
#
# `.dev.vars` is git-crypt-filtered; before you've run `./scripts/setup`
# the file on disk is encrypted bytes and `dotenv_if_exists` will
# silently fail to parse it. After unlock it's plaintext and loads
# cleanly.
#
# Authorize this file with `direnv allow .` (the setup script does
# that for you).
#
# Non-secret project defaults are exported here directly (no encryption,
# no 1Password round-trip). The Cloudflare account ID is the address of
# the account that hosts deploys + e2e infrastructure for this repo — it
# pairs naturally with `CLOUDFLARE_API_TOKEN` (which is encrypted in
# `.dev.vars`).

export CLOUDFLARE_ACCOUNT_ID=4ef06593037ec81daf64e272ab950efb

dotenv_if_exists .dev.vars
