{
  "name": "astroflare",
  "private": true,
  "version": "0.0.0",
  "description": "Cloudflare-native, Astro-compatible content framework",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "tsc -b packages/runtime && pnpm --filter @astroflare/host-cloudflare run regen-runtime-modules && pnpm --filter @astroflare/starter run regen-starter-files && tsc -b",
    "clean": "tsc -b --clean && rimraf 'packages/*/dist' 'examples/*/dist'",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "pnpm build && pnpm test:node && pnpm test:workerd",
    "test:node": "vitest run --project core --project compiler --project runtime --project preview --project build --project test-utils --project content --project cli --project cli-lib --project starter --project e2e --project repo --project conformance --project minimal-blog",
    "test:workerd": "node scripts/run-workerd-tests.mjs",
    "test:watch": "vitest",
    "test:coverage": "pnpm build && vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched"]
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "2.1.8",
    "esbuild": "^0.28.0",
    "happy-dom": "^15.11.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "workerd"]
  }
}
